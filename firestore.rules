rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match user documents in the 'users' collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Match emergency contacts subcollection under a specific user
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Match SOS activity history logs under a specific user
      match /sos_activities/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
